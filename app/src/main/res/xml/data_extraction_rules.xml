<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up the game save and leaderboard scores so users keep progress across installs -->
        <include domain="database" path="neon_joker.db"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="neon_joker.db"/>
    </device-transfer>
</data-extraction-rules>
